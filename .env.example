# =====================================================================
# DotArc Smart Wallet — Environment Variables
# =====================================================================
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local. It is gitignored.
# =====================================================================

# ---------------------------------------------------------------------
# Circle — backend only. Never exposed to the browser.
# ---------------------------------------------------------------------
# Get from console.circle.com. Use TEST_API_KEY:* for testnet.
CIRCLE_API_KEY=

# Random 32-byte hex string. Generate with: node scripts/generate-secret.mjs
# Register it once at console.circle.com after generating.
CIRCLE_ENTITY_SECRET=

# Created by running: node scripts/create-treasury.mjs
CIRCLE_TREASURY_WALLET_SET_ID=
CIRCLE_TREASURY_WALLET_ID=

# Created later when we add the agent feature. Leave blank for now.
CIRCLE_AGENT_WALLET_SET_ID=

# Secret for the /api/webhooks/circle endpoint.
# Set this to any strong random string, then configure Circle's dashboard
# to send "Authorization: Bearer <this value>" with each webhook notification.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CIRCLE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------
# Circle — safe to expose to the browser. Public app identifier.
# ---------------------------------------------------------------------
NEXT_PUBLIC_CIRCLE_APP_ID=

# ---------------------------------------------------------------------
# Arc Testnet — fixed values, do not change unless Arc redeploys.
# ---------------------------------------------------------------------
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ANS_REGISTRY_ADDRESS=0xf5e0E328119D16c75Fb4a001282a3a7b733EF6db
NEXT_PUBLIC_USDC_TOKEN_ADDRESS=0x3600000000000000000000000000000000000000
NEXT_PUBLIC_EURC_TOKEN_ADDRESS=0x89B50855Aa3bE2F677cD6303Cec089B5F319D72a
NEXT_PUBLIC_CIRBTC_TOKEN_ADDRESS=

# ---------------------------------------------------------------------
# App secrets
# ---------------------------------------------------------------------
# Random 32+ byte string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=

# HMAC key for signing agent policies (added when agent feature ships).
# Generate same way as JWT_SECRET. Leave blank for now.
POLICY_HMAC_SECRET=

# Pepper for deriving Circle userIds from emails. Without this, the
# email -> userId mapping is enumerable offline by anyone who knows
# emails. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: pick this value ONCE. Changing it remaps every email to a new
# Circle userId, which means every existing wallet is orphaned.
USER_ID_PEPPER=

# ---------------------------------------------------------------------
# Database (added in a later step — leave blank for now)
# ---------------------------------------------------------------------
DATABASE_URL=

# ---------------------------------------------------------------------
# Supabase Auth — used as the email-ownership gate before Circle.
# Get from: Supabase dashboard → Project Settings → API.
# Both are safe to expose to the browser (anon key has row-level-security).
# ---------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------
# App base URL — used for the shareable /pay/<name> link in the Receive modal.
# In development this is http://localhost:3000. In production: https://wallet.dotarc.my
# ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------
# OpenRouter — used by the Smart Agent to interpret user instructions.
# Get from: openrouter.ai/keys
# Default model: anthropic/claude-3.5-sonnet (override with OPENROUTER_MODEL)
# ---------------------------------------------------------------------

OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ---------------------------------------------------------------------
# Circle Kit Key — required for SWAP_USDC skill (token swaps via App Kit).
# NOT required for BRIDGE_USDC or PAY_X402.
# Get from: console.circle.com → Keys → + Create a key → Kit Key
# Kit keys are network-agnostic (same key works on testnet and mainnet).
# ---------------------------------------------------------------------
KIT_KEY=

# ---------------------------------------------------------------------
# Supabase service role — backend-only, NEVER expose to the browser.
# Used by the agent cron to read all policies (bypasses RLS).
# Get from: Supabase dashboard → Project Settings → API → service_role key
# ---------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------
# Cron secret — authenticates calls to /api/cron/agent-policies.
# On Vercel this is auto-injected when the cron fires (you still need
# to set it manually here for local testing / non-Vercel schedulers).
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ---------------------------------------------------------------------
CRON_SECRET=
