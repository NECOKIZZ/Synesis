# =====================================================================
# DotArc Smart Wallet — Environment Variables
# =====================================================================
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local. It is gitignored.
# =====================================================================

# ---------------------------------------------------------------------
# Circle — backend only. Never exposed to the browser.
# ---------------------------------------------------------------------
# Get from console.circle.com. Use TEST_API_KEY:* for testnet.
CIRCLE_API_KEY=

# Random 32-byte hex string. Generate with: node scripts/generate-secret.mjs
# Register it once at console.circle.com after generating.
CIRCLE_ENTITY_SECRET=

# Created by running: node scripts/create-treasury.mjs
CIRCLE_TREASURY_WALLET_SET_ID=
CIRCLE_TREASURY_WALLET_ID=

# Created later when we add the agent feature. Leave blank for now.
CIRCLE_AGENT_WALLET_SET_ID=

# /api/webhooks/circle authenticates each request using Circle's ECDSA
# signature (X-Circle-Signature + X-Circle-Key-Id headers), verified with
# Circle's published public key. No shared secret needed.
#
# Set CIRCLE_WEBHOOK_SKIP_VERIFY=true ONLY for local dev when you want to
# replay payloads from a curl. Never set this in production.
CIRCLE_WEBHOOK_SKIP_VERIFY=

# ---------------------------------------------------------------------
# Circle — safe to expose to the browser. Public app identifier.
# ---------------------------------------------------------------------
NEXT_PUBLIC_CIRCLE_APP_ID=

# ---------------------------------------------------------------------
# Arc Testnet — fixed values, do not change unless Arc redeploys.
# ---------------------------------------------------------------------
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ANS_REGISTRY_ADDRESS=0xf5e0E328119D16c75Fb4a001282a3a7b733EF6db
NEXT_PUBLIC_USDC_TOKEN_ADDRESS=0x3600000000000000000000000000000000000000
NEXT_PUBLIC_EURC_TOKEN_ADDRESS=0x89B50855Aa3bE2F677cD6303Cec089B5F319D72a
NEXT_PUBLIC_CIRBTC_TOKEN_ADDRESS=

# ---------------------------------------------------------------------
# App secrets
# ---------------------------------------------------------------------
# Random 32+ byte string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=

# HMAC key for signing agent policies (added when agent feature ships).
# Generate same way as JWT_SECRET. Leave blank for now.
POLICY_HMAC_SECRET=

# Pepper for deriving Circle userIds from emails. Without this, the
# email -> userId mapping is enumerable offline by anyone who knows
# emails. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: pick this value ONCE. Changing it remaps every email to a new
# Circle userId, which means every existing wallet is orphaned.
USER_ID_PEPPER=

# ---------------------------------------------------------------------
# Database (added in a later step — leave blank for now)
# ---------------------------------------------------------------------
DATABASE_URL=

# ---------------------------------------------------------------------
# Supabase Auth — used as the email-ownership gate before Circle.
# Get from: Supabase dashboard → Project Settings → API.
# Both are safe to expose to the browser (anon key has row-level-security).
# ---------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------
# App base URL — used for the shareable /pay/<name> link in the Receive modal.
# In development this is http://localhost:3000. In production: https://wallet.dotarc.my
# ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------
# OpenRouter — used by the Smart Agent to interpret user instructions.
# Get from: openrouter.ai/keys
# Default model: anthropic/claude-3.5-sonnet (override with OPENROUTER_MODEL)
# ---------------------------------------------------------------------

OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Resilience (lib/resilience.ts) — bound the interpret call so a flaky egress
# path fails fast with a friendly error instead of a 30–50s hang (F-1/F-2).
# Per-attempt timeout in ms; interpret is read-only so one retry is safe.
OPENROUTER_TIMEOUT_MS=12000
OPENROUTER_MAX_RETRIES=1

# ---------------------------------------------------------------------
# Circle Kit Key — required for SWAP_USDC skill (token swaps via App Kit).
# NOT required for BRIDGE_USDC or PAY_X402.
# Get from: console.circle.com → Keys → + Create a key → Kit Key
# Kit keys are network-agnostic (same key works on testnet and mainnet).
# ---------------------------------------------------------------------
KIT_KEY=

# ---------------------------------------------------------------------
# BRIDGE_USDC (CCTP via App Kit forwarder mode). Both optional.
# ---------------------------------------------------------------------
# Max CCTP fast-transfer fee to pay on the burn, in USDC. MUST be smaller
# than the bridged amount or the burn reverts ("Max fee must be less than
# amount"). Arc's fast fee floor is ~1.4 USDC; 1.50 leaves headroom.
BRIDGE_MAX_FEE=1.50
# Reject bridges from Arc below this amount up front (must exceed the fee
# floor above). Keep >= ~1.5.
ARC_MIN_BRIDGE_USDC=2

# ---------------------------------------------------------------------
# Solana (devnet) — program interaction via Circle's Signing API.
# Off by default. Flip requires a process restart so the registry, the
# VALID_LEAF_SKILLS validator, and the LLM catalog stay in lock-step.
# ---------------------------------------------------------------------
SOLANA_ENABLED=false
# RPC endpoint. Default is public devnet; override with a dedicated provider
# (Helius/QuickNode) for reliability.
SOLANA_RPC_URL=https://api.devnet.solana.com
# Circle's USDC mint on Solana devnet. Verify against the Circle faucet.
SOLANA_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# Optional knobs (sane defaults in lib/solana/config.ts):
#   SOLANA_PRIORITY_FEE_MICROLAMPORTS=1000
#   SOLANA_COMPUTE_UNIT_LIMIT=200000
#   SOLANA_MIN_FEE_LAMPORTS=5000000   # 0.005 SOL min before signing
#   SOLANA_SIGN_TIMEOUT_MS=20000
#   SOLANA_EXPLORER_CLUSTER=devnet

# ---------------------------------------------------------------------
# Supabase service role — backend-only, NEVER expose to the browser.
# Used by the agent cron to read all policies (bypasses RLS).
# Get from: Supabase dashboard → Project Settings → API → service_role key
# ---------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------
# Cron secret — authenticates calls to /api/cron/agent-policies.
# On Vercel this is auto-injected when the cron fires (you still need
# to set it manually here for local testing / non-Vercel schedulers).
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ---------------------------------------------------------------------
CRON_SECRET=

# ---------------------------------------------------------------------
# V3.5 — Memory & injection upgrades. Each flag gates exactly one change
# and can be flipped independently. Default OFF: V3 behavior is byte-
# identical until proven on localhost (see dotarc-agent-v3.5-implementation.md).
# ---------------------------------------------------------------------
# Track 1 — serve the LLM's balance context from the webhook-maintained
# cache (fast DB read) instead of a live Circle call. Spend-time gates
# still read Circle live regardless of this flag.
BALANCE_CACHE_ENABLED=false
# Track 3 — inject a one-line identity hint ("You are talking to
# <name>.arc.") so the model can personalise wording. Omitted for users
# with no registered .arc name.
AGENT_IDENTITY_INJECT=false
# Track 2 — register the RETRIEVE_TRANSACTIONS skill so the agent can
# answer history questions ("what did I send last week?", "how much
# have I tipped sara?"). Read-only — never moves funds. When off, the
# skill is absent from BOTH the registry and the LLM catalog prose, so
# the model never emits it. Flip requires a process restart so the
# catalog and registry stay in lock-step within a single boot.
RETRIEVE_TRANSACTIONS_ENABLED=false
# Track 4 — pgvector semantic skill router. When on, each interpret call
# embeds the user message and injects only the top-K most relevant skill
# descriptions instead of the full hardcoded catalog. Requires migration
# 0014_skill_embeddings.sql applied AND scripts/seed-skill-embeddings.ts
# run. The router self-falls-back to the full catalog on any failure, so a
# router outage never breaks interpret. When off, the prompt is byte-
# identical to V3.
SKILL_ROUTER_ENABLED=false
# Number of skills to inject on a confident match (default 6).
SKILL_ROUTER_K=6
# Minimum cosine similarity for the top match; below this the router logs a
# miss to skill_router_misses and injects the full catalog (default 0.4).
SKILL_ROUTER_MIN_COSINE=0.4
# Embeddings (skill router). Two ways to provide them:
#   A) Via OpenRouter (recommended — reuses your existing OPENROUTER_API_KEY,
#      no separate OpenAI account). Set:
#        OPENAI_API_BASE=https://openrouter.ai/api
#        EMBEDDING_MODEL=openai/text-embedding-3-small
#      and leave OPENAI_API_KEY blank — the module falls back to
#      OPENROUTER_API_KEY automatically when the base points at openrouter.ai.
#   B) Direct OpenAI: set OPENAI_API_KEY=sk-... and leave the two vars unset.
# Required only when SKILL_ROUTER_ENABLED=true or to run the seed script.
OPENAI_API_KEY=
# OPENAI_API_BASE=https://openrouter.ai/api
# EMBEDDING_MODEL=openai/text-embedding-3-small
# Intent-gated contact memory. When on, each interpret call injects the
# "who you've dealt with" digest from agent_contact_mem — but ONLY when the
# skill router selected a contact-feeding skill (SEND_USDC / SEND_TOKEN), so
# casual messages ("hello") get no contact block. Requires migration
# 0015_agent_contact_mem.sql applied. Best-effort: a memory miss never
# breaks interpret. When off, the prompt is byte-identical to before.
CONTACT_MEM_INJECT=false
# Durable always-on personalization. When on, each interpret call injects the
# user's profile card (communication style + standing preferences) right after
# the identity line, and the session-end job merges new durable facts into that
# card. Requires migration 0018_user_profile.sql applied. Best-effort: a miss
# omits the block. When off, the prompt is byte-identical and no merge runs.
USER_PROFILE_ENABLED=false
# Optional overrides for the embedding model / endpoint.
# EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_BASE=https://api.openai.com
# Embedding resilience (lib/resilience.ts). Interactive path (router embeds
# every message) → bound it so a slow provider fails fast and the router
# falls back to the full catalog. One retry is safe (read-only).
# EMBEDDING_TIMEOUT_MS=8000
# EMBEDDING_MAX_RETRIES=1

# ---------------------------------------------------------------------
# ANS (.arc name) resolution resilience (lib/resilience.ts). A transient
# Arc RPC blip now self-heals with one bounded retry before surfacing a
# "couldn't verify, try again" (F-17); a sustained outage trips the shared
# "arc-rpc" breaker so lookups fail fast instead of hanging.
# ---------------------------------------------------------------------
# ANS_TIMEOUT_MS=8000
# ANS_MAX_RETRIES=1
